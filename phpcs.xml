<?xml version="1.0"?>
<ruleset name="Term Order Per Post">
    <description>PHPCS rules for Term Order Per Post plugin</description>

    <file>src</file>
    <file>whaze-term-order-for-posts.php</file>

    <arg name="extensions" value="php"/>
    <arg value="sp"/>

    <rule ref="WordPress-Core"/>
    <rule ref="WordPress-Docs"/>
    <rule ref="WordPress-Extra"/>

    <rule ref="WordPress.NamingConventions.PrefixAllGlobals">
        <properties>
            <property name="prefixes" type="array">
                <element value="whaze_term_order_for_posts"/>
                <element value="WHAZE_TERM_ORDER_FOR_POSTS"/>
                <element value="Whaze\TermOrderPerPost"/>
            </property>
        </properties>
    </rule>

    <rule ref="WordPress.WP.I18n">
        <properties>
            <property name="text_domain" type="array">
                <element value="whaze-term-order-for-posts"/>
            </property>
        </properties>
    </rule>

    <config name="minimum_supported_wp_version" value="6.0"/>

    <!--
        PSR-4 autoloading requires StudlyCaps filenames (e.g. OrderStorage.php).
        WordPress file naming conventions (class-order-storage.php) are incompatible.
    -->
    <rule ref="WordPress.Files.FileName.NotHyphenatedLowercase">
        <exclude-pattern>src/*</exclude-pattern>
    </rule>
    <rule ref="WordPress.Files.FileName.InvalidClassFileName">
        <exclude-pattern>src/*</exclude-pattern>
    </rule>

    <!--
        Short array syntax [] is idiomatic PHP 8.0+ and used throughout the codebase.
    -->
    <rule ref="Universal.Arrays.DisallowShortArraySyntax">
        <severity>0</severity>
    </rule>

    <!--
        camelCase method names are used in PSR-4 classes.
        WordPress snake_case convention applies to procedural/global-scope functions only.
    -->
    <rule ref="WordPress.NamingConventions.ValidFunctionName.MethodNameInvalid">
        <exclude-pattern>src/*</exclude-pattern>
    </rule>

    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/node_modules/*</exclude-pattern>
    <exclude-pattern>*/assets/build/*</exclude-pattern>
</ruleset>
