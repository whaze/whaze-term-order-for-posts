{
    "name": "whaze-term-order-for-posts",
    "version": "1.0.0",
    "description": "Order taxonomy terms individually per post, directly from the Gutenberg editor sidebar.",
    "private": true,
    "files": [
        "assets",
        "languages",
        "src",
        "vendor",
        "composer.json",
        "readme.txt",
        "whaze-term-order-for-posts.php"
    ],
    "scripts": {
        "build": "wp-scripts build assets/src/index.js assets/src/admin.js --output-path=assets/build",
        "start": "wp-scripts start assets/src/index.js assets/src/admin.js --output-path=assets/build",
        "lint:js": "wp-scripts lint-js assets/src",
        "make-pot": "wp i18n make-pot . languages/whaze-term-order-for-posts.pot --domain=whaze-term-order-for-posts --exclude=vendor,node_modules,assets/build",
        "make-mo": "rm -f languages/*.mo languages/*.php && wp i18n make-mo languages/",
        "make-json": "wp i18n make-json languages/ --no-purge",
        "update-po": "wp i18n update-po languages/whaze-term-order-for-posts.pot languages/",
        "i18n": "npm run make-pot && npm run update-po && npm run make-mo && npm run make-json",
        "plugin-zip": "wp-scripts plugin-zip"
    },
    "dependencies": {
        "@dnd-kit/core": "^6.3.1",
        "@dnd-kit/sortable": "^10.0.0",
        "@dnd-kit/utilities": "^3.2.2"
    },
    "devDependencies": {
        "@wordpress/element": "*",
        "@wordpress/scripts": "^32.0.0"
    }
}
