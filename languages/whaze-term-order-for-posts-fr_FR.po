#. Plugin Name of the plugin
#: whaze-term-order-for-posts.php
msgid "Whaze Term Order for Posts"
msgstr "Whaze : ordre des termes par article"

#. Description of the plugin
#: whaze-term-order-for-posts.php
msgid "Order taxonomy terms individually per post, directly from the Gutenberg editor sidebar."
msgstr "Ordonnez les termes de taxonomie individuellement par article, directement depuis le panneau latéral de l'éditeur Gutenberg."

#. Author of the plugin
#: whaze-term-order-for-posts.php
msgid "Jérôme Buquet"
msgstr ""

#. Author URI of the plugin
#: whaze-term-order-for-posts.php
msgid "https://profiles.wordpress.org/whaze/"
msgstr ""

#: src/functions.php:123
msgid "whaze_term_order_for_posts_register() must be called after the plugins_loaded hook."
msgstr "whaze_term_order_for_posts_register() doit être appelée après le hook plugins_loaded."

#: src/RestField.php:46
msgid "Custom term order per taxonomy."
msgstr "Ordre personnalisé des termes par taxonomie."

#: src/RestField.php:88
msgid "term_order must be an object mapping taxonomy slugs to arrays of term IDs."
msgstr "term_order doit être un objet associant des slugs de taxonomie à des tableaux d'IDs de termes."

#: src/RestField.php:96
msgid "You do not have permission to edit this post."
msgstr "Vous n'avez pas la permission de modifier cet article."

#. translators: %s: taxonomy slug
#: src/RestField.php:115
#, php-format
msgid "Term IDs for taxonomy \"%s\" must be an array."
msgstr "Les IDs de termes pour la taxonomie « %s » doivent être un tableau."

#. translators: 1: taxonomy slug, 2: comma-separated list of invalid IDs
#: src/RestField.php:159
#, php-format
msgid "The following term IDs are not assigned to this post in taxonomy \"%1$s\": %2$s"
msgstr "Les IDs de termes suivants ne sont pas assignés à cet article dans la taxonomie « %1$s » : %2$s"

#: assets/src/components/SortableTermList.js:59
msgid "Drag to reorder"
msgstr "Glisser pour réordonner"

#. translators: %s: taxonomy name
#: assets/src/components/TermOrderPanel.js:57
#, js-format
msgid "Assign terms first using the %s panel to order them here."
msgstr "Assignez d'abord des termes via le panneau %s pour les ordonner ici."

#. translators: %s: taxonomy label, e.g. "Genres"
#: assets/src/index.js:15
#, js-format
msgid "%s (order)"
msgstr "%s (ordre)"

#. Plugin URI of the plugin
#: whaze-term-order-for-posts.php
msgid "https://github.com/whaze/whaze-term-order-for-posts"
msgstr ""

#: src/Admin/SettingsPage.php:51
#: src/Admin/SettingsPage.php:52
msgid "Term Order for Posts"
msgstr "Ordre des termes par article"

#: src/Admin/SettingsRegistration.php:43
msgid "Automatically apply custom term order via wp_get_object_terms()."
msgstr "Appliquer automatiquement l'ordre personnalisé des termes via wp_get_object_terms()."

#: src/Admin/SettingsRegistration.php:54
msgid "Post type / taxonomy pairs with custom term ordering enabled."
msgstr "Paires type d'article / taxonomie avec ordonnancement personnalisé activé."

#. translators: 1: post type slug, 2: taxonomy slug
#: src/Admin/SettingsRegistration.php:113
#, php-format
msgid "Invalid post type or taxonomy: \"%1$s\" / \"%2$s\". The pair was not saved."
msgstr "Type d'article ou taxonomie invalide : « %1$s » / « %2$s ». La paire n'a pas été enregistrée."

#. translators: 1: taxonomy slug, 2: post type slug
#: src/Admin/SettingsRegistration.php:127
#, php-format
msgid "Taxonomy \"%1$s\" is not registered for post type \"%2$s\". The pair was not saved."
msgstr "La taxonomie « %1$s » n'est pas enregistrée pour le type d'article « %2$s ». La paire n'a pas été enregistrée."

#: assets/src/admin/RegistrationsMatrix.js:32
msgid "No post types with UI-visible taxonomies found."
msgstr "Aucun type d'article avec des taxonomies visibles dans l'interface n'a été trouvé."

#: assets/src/admin/RegistrationsMatrix.js:66
msgid "Registered via code"
msgstr "Enregistré via le code"

#: assets/src/admin/SettingsApp.js:44
msgid "Settings saved."
msgstr "Paramètres enregistrés."

#. translators: %s: error message
#: assets/src/admin/SettingsApp.js:51
#, js-format
msgid "Could not save settings: %s"
msgstr "Impossible d'enregistrer les paramètres : %s"

#: assets/src/admin/SettingsApp.js:56
msgid "Unknown error."
msgstr "Erreur inconnue."

#: assets/src/admin/SettingsApp.js:66
msgid "Term Order for Posts — Settings"
msgstr "Ordre des termes par article — Paramètres"

#: assets/src/admin/SettingsApp.js:83
msgid "Post type / taxonomy pairs"
msgstr "Paires type d'article / taxonomie"

#: assets/src/admin/SettingsApp.js:89
msgid "Enable term ordering for each post type and taxonomy combination. Pairs registered via code are shown as read-only."
msgstr "Activez l'ordonnancement des termes pour chaque combinaison type d'article / taxonomie. Les paires enregistrées via le code sont affichées en lecture seule."

#: assets/src/admin/SettingsApp.js:127
msgid "Save Settings"
msgstr "Enregistrer les paramètres"

#: assets/src/admin/SettingsApp.js:102
msgid "Frontend rendering"
msgstr "Rendu frontend"

#: assets/src/admin/SettingsApp.js:108
msgid "Automatically apply custom order (native blocks, themes, REST API)"
msgstr "Appliquer automatiquement l'ordre personnalisé (blocs natifs, thèmes, REST API)"

#: assets/src/admin/SettingsApp.js:112
msgid "Hooks into get_the_terms(). Applies to all registered pairs. No code required."
msgstr "S'accroche à get_the_terms(). S'applique à toutes les paires enregistrées. Aucun code requis."
